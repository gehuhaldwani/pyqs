---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div"> & {
  /**
   * When true, the dropdown will open on hover in addition to click
   */
  openOnHover?: boolean;
  /**
   * Time in milliseconds to wait before closing when hover open is enabled
   * @default 200
   */
  closeDelay?: number;
  menuMode?: "dropdown" | "context-menu";

  children: any;
};

const {
  class: className,
  openOnHover = false,
  closeDelay = 200,
  menuMode = "dropdown",
  ...rest
} = Astro.props;
---

<div
  class:list={[
    "starwind-dropdown",
    menuMode === "context-menu" && "starwind-context-menu",
    "relative",
    className,
  ]}
  data-menu-mode={menuMode}
  data-open-on-hover={openOnHover ? "true" : undefined}
  data-close-delay={closeDelay}
  {...rest}
  data-slot={menuMode}
>
  <slot />
</div>

<script>
  import {
    type FloatingAlign,
    type FloatingSide,
    getTransformOrigin,
    resolvePlacement,
  } from "@/lib/utils/starwind/positioning";

  class DropdownHandler {
    private dropdown: HTMLElement;
    private trigger: HTMLElement | null;
    private content: HTMLElement | null;
    private items: HTMLElement[] = [];
    private currentFocusIndex: number = -1;
    private isOpen: boolean = false;
    private isClosing: boolean = false;
    private animationDuration = 150;
    private side: FloatingSide = "bottom";
    private align: FloatingAlign = "start";
    private sideOffset = 4;
    private openOnHover: boolean;
    private closeDelay: number;
    private closeTimerRef: number | null = null;
    private closeTimeoutRef: number | null = null;
    private lastOpenSource: "keyboard" | "mouse" = "keyboard";
    private lastCloseSource: "keyboard" | "mouse" = "keyboard";
    private isSubmenu: boolean;
    private rootDropdown: HTMLElement;
    private contentPlaceholder: Comment | null = null;
    private portalTarget: HTMLElement | null = null;
    private cleanupAutoUpdate: (() => void) | null = null;
    private openChildCount: number = 0;
    private parentHandler: DropdownHandler | null = null;
    private abortController: AbortController;
    private isContextMenu: boolean;
    private anchorRect: DOMRect | null = null;
    private initialCursorPoint: { x: number; y: number } | null = null;
    private touchStartPoint: { x: number; y: number } | null = null;
    private longPressTimerRef: number | null = null;
    private suppressTouchContextMenuUntil = 0;
    private suppressTouchTriggerCloseUntil = 0;
    private skipParentHoverCloseOnUnmount = false;

    constructor(dropdown: HTMLElement, dropdownIdx: number) {
      this.dropdown = dropdown;
      this.abortController = new AbortController();
      this.isSubmenu = dropdown.classList.contains("starwind-dropdown-sub");
      this.isContextMenu = dropdown.getAttribute("data-menu-mode") === "context-menu";
      this.openOnHover = dropdown.getAttribute("data-open-on-hover") === "true" || this.isSubmenu;
      this.closeDelay = parseInt(dropdown.getAttribute("data-close-delay") || "200");

      // Find the trigger and content that belong to this dropdown, avoiding nested ones
      this.trigger = this.findOwnElement(
        '[data-slot="dropdown-trigger"], [data-slot="context-menu-trigger"], [data-sub-trigger]',
      );

      // if trigger is set with asChild, use the first child element for trigger button
      if (this.trigger?.hasAttribute("data-as-child")) {
        this.trigger = this.trigger.firstElementChild as HTMLElement;
      }

      this.content = this.findOwnElement(
        '[data-slot="dropdown-content"], [data-slot="context-menu-content"]',
      );

      // Resolve root dropdown before any portaling (DOM is in original state)
      this.rootDropdown =
        (this.dropdown.closest(".starwind-dropdown") as HTMLElement) || this.dropdown;

      // Store handler reference and root dropdown on content element for lookups
      if (this.content) {
        (this.content as any).__dropdownHandler = this;
        (this.content as any).__rootDropdown = this.rootDropdown;
      }

      if (!this.trigger || !this.content) return;

      // Get animation duration from inline styles if available
      const animationDurationString = this.content.style.animationDuration;
      if (animationDurationString.endsWith("ms")) {
        this.animationDuration = parseFloat(animationDurationString);
      } else if (animationDurationString.endsWith("s")) {
        this.animationDuration = parseFloat(animationDurationString) * 1000;
      }

      if (this.isSubmenu) {
        this.side = "right";
        this.align = "start";
        this.sideOffset = 0;
      }

      const contentSide = this.content.getAttribute("data-side");
      if (
        contentSide === "top" ||
        contentSide === "bottom" ||
        contentSide === "left" ||
        contentSide === "right"
      ) {
        this.side = contentSide;
      }

      const contentAlign = this.content.getAttribute("data-align");
      if (contentAlign === "start" || contentAlign === "center" || contentAlign === "end") {
        this.align = contentAlign;
      }

      const contentSideOffset = parseFloat(
        this.content.getAttribute("data-side-offset") || `${this.sideOffset}`,
      );
      if (Number.isFinite(contentSideOffset)) {
        this.sideOffset = contentSideOffset;
      }

      this.init(dropdownIdx);
    }

    private findOwnElement(selector: string): HTMLElement | null {
      const elements = this.dropdown.querySelectorAll(selector);
      for (const el of elements) {
        if (el.closest(".starwind-dropdown, .starwind-dropdown-sub") === this.dropdown) {
          return el as HTMLElement;
        }
      }
      return null;
    }

    private resolvePortalTarget(): HTMLElement {
      const currentFloatingRoot = this.trigger?.closest("[data-floating-root]");
      if (currentFloatingRoot instanceof HTMLElement) {
        return currentFloatingRoot;
      }

      const dialogHost = this.trigger?.closest(
        'dialog[data-slot="dialog-content"], dialog[data-slot="sheet-content"]',
      );
      const dialogFloatingRoot = dialogHost?.querySelector(":scope > [data-floating-root]");
      if (dialogFloatingRoot instanceof HTMLElement) {
        return dialogFloatingRoot;
      }

      return document.body;
    }

    private init(dropdownIdx: number) {
      this.setupAccessibility(dropdownIdx);
      this.setupEvents();
    }

    private setupAccessibility(dropdownIdx: number) {
      if (!this.trigger || !this.content) return;

      // Generate unique IDs for accessibility
      const idPrefix = this.isContextMenu ? "starwind-context-menu" : "starwind-dropdown";
      this.trigger.id = `${idPrefix}${dropdownIdx}-trigger`;
      this.content.id = `${idPrefix}${dropdownIdx}-content`;

      // Set up additional ARIA attributes
      this.trigger.setAttribute("aria-controls", this.content.id);
      this.content.setAttribute("aria-labelledby", this.trigger.id);
    }

    private setupEvents() {
      if (!this.trigger || !this.content) return;

      if (this.isContextMenu && !this.isSubmenu) {
        this.setupContextMenuEvents();
      } else {
        // Handle trigger click
        this.trigger.addEventListener(
          "click",
          (e) => {
            e.preventDefault();
            this.lastOpenSource = e.detail === 0 ? "keyboard" : "mouse";
            this.toggleDropdown();
          },
          { signal: this.abortController.signal },
        );
      }

      // Handle keyboard navigation on trigger
      this.trigger.addEventListener(
        "keydown",
        (e) => {
          if (
            this.isContextMenu &&
            !this.isSubmenu &&
            (e.key === "ContextMenu" || (e.shiftKey && e.key === "F10"))
          ) {
            e.preventDefault();
            e.stopPropagation();
            this.lastOpenSource = "keyboard";
            this.openAtTrigger();
          } else if (!this.isContextMenu && (e.key === "Enter" || e.key === " ")) {
            e.preventDefault();
            e.stopPropagation();
            this.lastOpenSource = "keyboard";
            if (this.isSubmenu) {
              this.openDropdown();
            } else {
              this.toggleDropdown();
            }
          } else if (e.key === "Escape" && this.isOpen) {
            e.preventDefault();
            e.stopPropagation();
            this.lastCloseSource = "keyboard";
            // Close all menus in the group, focus root trigger
            this.rootDropdown.dispatchEvent(
              new CustomEvent("starwind-dropdown:close-all", { detail: { focusRoot: true } }),
            );
          } else if (this.isOpen && (e.key === "ArrowDown" || e.key === "ArrowUp")) {
            e.preventDefault();
            e.stopPropagation();
            this.lastOpenSource = "keyboard";
            this.updateDropdownItems();
            if (e.key === "ArrowDown") {
              this.focusItem(0); // Focus first item when opening with arrow down
            } else {
              this.focusItem(this.items.length - 1); // Focus last item when opening with arrow up
            }
          } else if (e.key === "ArrowRight" && this.isSubmenu) {
            e.preventDefault();
            e.stopPropagation();
            if (!this.isOpen) {
              this.lastOpenSource = "keyboard";
              this.openDropdown();
            } else {
              this.updateDropdownItems();
              this.focusItem(0);
            }
          }
        },
        { signal: this.abortController.signal },
      );

      // Listen for close-all event (routed through rootDropdown to work across portaled content)
      this.rootDropdown.addEventListener(
        "starwind-dropdown:close-all",
        ((e: CustomEvent) => {
          this.closeDropdown({ skipFocus: e.detail?.focusRoot && this.isSubmenu });
        }) as EventListener,
        { signal: this.abortController.signal },
      );

      // Listen for cancel-close event (routed through rootDropdown)
      this.rootDropdown.addEventListener(
        "starwind-dropdown:cancel-close",
        () => {
          this.clearCloseTimer();
        },
        { signal: this.abortController.signal },
      );

      // Close dropdown when clicking outside for mouse
      document.addEventListener(
        "pointerdown",
        (e) => {
          if (
            this.isOpen &&
            (this.isContextMenu && !this.isSubmenu
              ? this.shouldCloseContextMenuFromTarget(e.target as Node)
              : !this.dropdown.contains(e.target as Node)) &&
            !this.content?.contains(e.target as Node) &&
            !this.isTargetInGroup(e.target as Node)
          ) {
            if (e.button === 0 && e.ctrlKey === false && e.pointerType === "mouse") {
              this.closeDropdown();
            }
          }
        },
        { signal: this.abortController.signal },
      );

      // Handle click outside select content to close for mobile
      document.addEventListener(
        "click",
        (e) => {
          if (
            this.isOpen &&
            (this.isContextMenu && !this.isSubmenu
              ? this.shouldCloseContextMenuFromTarget(e.target as Node)
              : !this.trigger?.contains(e.target as Node)) &&
            !this.content?.contains(e.target as Node) &&
            !this.isTargetInGroup(e.target as Node)
          ) {
            this.closeDropdown();
          }
        },
        { signal: this.abortController.signal },
      );

      // Handle keyboard navigation and item selection within dropdown
      this.content.addEventListener(
        "keydown",
        (e) => {
          if (e.key === "Escape") {
            e.preventDefault();
            e.stopPropagation();
            this.lastCloseSource = "keyboard";
            // Close all menus in the group, focus root trigger
            this.rootDropdown.dispatchEvent(
              new CustomEvent("starwind-dropdown:close-all", { detail: { focusRoot: true } }),
            );
          } else if (this.isOpen) {
            this.handleMenuKeydown(e);
          }
        },
        { signal: this.abortController.signal },
      );

      // Handle item selection
      this.content.addEventListener(
        "mouseup",
        (e) => {
          if (!this.isContextMenu || this.isSubmenu || !this.initialCursorPoint) return;
          const isOpeningPointer =
            Math.abs(e.clientX - this.initialCursorPoint.x) <= 1 &&
            Math.abs(e.clientY - this.initialCursorPoint.y) <= 1;
          this.initialCursorPoint = null;
          if (isOpeningPointer || e.button === 2) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        { signal: this.abortController.signal },
      );

      this.content.addEventListener(
        "click",
        (e) => {
          const target = e.target as HTMLElement;
          const item = target.closest('[role="menuitem"], [role="menuitemcheckbox"]');
          if (item && !(item as HTMLElement).hasAttribute("data-disabled")) {
            if (item.hasAttribute("aria-haspopup")) return;
            if (item.getAttribute("role") === "menuitemcheckbox") {
              this.toggleCheckboxItem(item as HTMLElement);
              if ((item as HTMLElement).getAttribute("data-close-on-click") !== "true") return;
            }

            // Close the dropdown after item selection
            this.closeDropdown();

            // Dispatch close-all through root to close all menus in the group
            this.rootDropdown.dispatchEvent(new CustomEvent("starwind-dropdown:close-all"));
          }
        },
        { signal: this.abortController.signal },
      );

      // Handle hover on dropdown items
      this.content.addEventListener(
        "mouseover",
        (e) => {
          const target = e.target as HTMLElement;
          const menuItem = target.closest('[role="menuitem"], [role="menuitemcheckbox"]');
          if (
            menuItem &&
            menuItem instanceof HTMLElement &&
            !menuItem.hasAttribute("data-disabled") &&
            this.isOpen === true
          ) {
            // Update items list before focusing to ensure the index is correct
            this.updateDropdownItems();

            const itemIndex = this.items.indexOf(menuItem);
            if (itemIndex === -1) return;

            // Focus the item when hovering
            this.focusItem(itemIndex);
          }
        },
        { signal: this.abortController.signal },
      );

      if (this.openOnHover) {
        this.trigger.addEventListener(
          "pointerenter",
          (e) => {
            if (e.pointerType !== "mouse") return;
            if (this.isClosing) return;
            if (!this.isOpen) {
              this.lastOpenSource = "mouse";
              this.openDropdown();
            } else {
              // If the dropdown is already open, make sure to clear any close timer
              this.clearCloseTimer();
            }
          },
          { signal: this.abortController.signal },
        );

        this.dropdown.addEventListener(
          "pointerleave",
          (e) => {
            if (e.pointerType !== "mouse") return;
            if (this.openChildCount > 0) return;
            if (this.isOpen) {
              this.lastCloseSource = "mouse";
              this.closeDropdownDelayed();
            }
          },
          { signal: this.abortController.signal },
        );

        this.content.addEventListener(
          "pointerenter",
          (e) => {
            if (e.pointerType !== "mouse") return;
            // If the user moves the mouse to the content, cancel the close timer
            this.clearCloseTimer();
          },
          { signal: this.abortController.signal },
        );
      }
    }

    private setupContextMenuEvents() {
      if (!this.trigger) return;

      this.trigger.addEventListener(
        "contextmenu",
        (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (Date.now() < this.suppressTouchContextMenuUntil) return;
          this.lastOpenSource = "mouse";
          this.openAtPoint(e.clientX, e.clientY);
        },
        { signal: this.abortController.signal },
      );

      this.trigger.addEventListener(
        "touchstart",
        (e) => {
          if (e.touches.length !== 1) {
            this.clearLongPressTimer();
            this.touchStartPoint = null;
            return;
          }
          const touch = e.touches[0];
          this.touchStartPoint = { x: touch.clientX, y: touch.clientY };
          this.clearLongPressTimer();
          this.longPressTimerRef = window.setTimeout(() => {
            if (!this.touchStartPoint) return;
            this.lastOpenSource = "mouse";
            this.openAtPoint(this.touchStartPoint.x, this.touchStartPoint.y, 10, 10);
            this.suppressTouchContextMenuUntil = Date.now() + 700;
            this.suppressTouchTriggerCloseUntil = Date.now() + 700;
          }, 500);
        },
        { signal: this.abortController.signal },
      );

      this.trigger.addEventListener(
        "touchmove",
        (e) => {
          if (e.touches.length !== 1) {
            this.clearLongPressTimer();
            return;
          }
          if (!this.touchStartPoint) return;
          const touch = e.touches[0];
          const deltaX = Math.abs(touch.clientX - this.touchStartPoint.x);
          const deltaY = Math.abs(touch.clientY - this.touchStartPoint.y);
          if (deltaX > 10 || deltaY > 10) {
            this.clearLongPressTimer();
          }
        },
        { signal: this.abortController.signal },
      );

      const handleTouchEnd = () => {
        this.clearLongPressTimer();
        this.touchStartPoint = null;
      };

      this.trigger.addEventListener("touchend", handleTouchEnd, {
        signal: this.abortController.signal,
      });
      this.trigger.addEventListener("touchcancel", handleTouchEnd, {
        signal: this.abortController.signal,
      });
    }

    private openAtPoint(x: number, y: number, width = 0, height = 0) {
      this.anchorRect = new DOMRect(x, y, width, height);
      this.initialCursorPoint = { x, y };
      if (this.isOpen) {
        this.positionContent({ avoidCollisions: true });
        return;
      }
      this.openDropdown();
    }

    private openAtTrigger() {
      if (!this.trigger) return;
      const rect = this.trigger.getBoundingClientRect();
      this.openAtPoint(rect.left, rect.bottom);
    }

    private handleMenuKeydown(e: KeyboardEvent) {
      // Make sure we've got an updated list of menu items
      this.updateDropdownItems();

      // Skip if no items
      if (this.items.length === 0) return;

      const currentIdx = this.currentFocusIndex;
      const currentItem = this.items[currentIdx];

      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          e.stopPropagation();
          this.focusItem(currentIdx === -1 ? 0 : currentIdx + 1);
          break;
        case "ArrowUp":
          e.preventDefault();
          e.stopPropagation();
          this.focusItem(currentIdx === -1 ? this.items.length - 1 : currentIdx - 1);
          break;
        case "ArrowRight":
          if (currentItem?.getAttribute("aria-haspopup") === "true") {
            e.preventDefault();
            e.stopPropagation();
            currentItem.click();
          }
          break;
        case "ArrowLeft":
          if (this.isSubmenu) {
            e.preventDefault();
            e.stopPropagation();
            this.closeDropdown({ skipParentHoverClose: true });
          }
          break;
        case "Home":
          e.preventDefault();
          e.stopPropagation();
          this.focusItem(0);
          break;
        case "End":
          e.preventDefault();
          e.stopPropagation();
          this.focusItem(this.items.length - 1);
          break;
        case "Enter":
        case " ":
          if (currentIdx !== -1) {
            e.preventDefault();
            e.stopPropagation();
            this.items[currentIdx].click();
          }
          break;
      }
    }

    private isTargetInGroup(target: Node): boolean {
      const el = target instanceof HTMLElement ? target : target.parentElement;
      if (!el) return false;
      const contentEl = el.closest(
        '[data-slot="dropdown-content"], [data-slot="context-menu-content"]',
      );
      return !!contentEl && (contentEl as any).__rootDropdown === this.rootDropdown;
    }

    private shouldCloseContextMenuFromTarget(target: Node): boolean {
      if (Date.now() < this.suppressTouchTriggerCloseUntil && this.trigger?.contains(target)) {
        return false;
      }

      return true;
    }

    private updateDropdownItems() {
      if (!this.content) return;
      // Get all interactive menuitem elements belonging to this menu level only
      this.items = (
        Array.from(
          this.content.querySelectorAll(
            '[role="menuitem"]:not([data-disabled="true"]), [role="menuitemcheckbox"]:not([data-disabled="true"])',
          ),
        ) as HTMLElement[]
      ).filter((item) => item.closest('[role="menu"]') === this.content);
      this.content
        .querySelectorAll('[role="menuitem"], [role="menuitemcheckbox"]')
        .forEach((item) => {
          if (item.closest('[role="menu"]') === this.content) {
            item.setAttribute("tabindex", "-1");
          }
        });
    }

    private toggleCheckboxItem(item: HTMLElement) {
      const checked = item.getAttribute("aria-checked") === "true";
      const nextChecked = !checked;
      item.setAttribute("aria-checked", String(nextChecked));
      item.dispatchEvent(
        new CustomEvent("starwind-dropdown-checkbox:change", {
          detail: { checked: nextChecked },
          bubbles: true,
        }),
      );
    }

    private focusItem(idx: number) {
      // Ensure the index wraps around properly
      const targetIdx = (idx + this.items.length) % this.items.length;

      if (this.items[targetIdx]) {
        this.items.forEach((item) => item.setAttribute("tabindex", "-1"));
        this.items[targetIdx].setAttribute("tabindex", "0");
        this.items[targetIdx].focus();
        this.currentFocusIndex = targetIdx;
      }
    }

    private toggleDropdown() {
      if (this.isOpen) {
        this.closeDropdown();
      } else {
        this.openDropdown();
      }
    }

    private openDropdown() {
      if (this.isClosing) return;
      if (!this.content || !this.trigger || (this.trigger as any).disabled) return;

      this.isOpen = true;
      this.trigger.setAttribute("aria-expanded", "true");
      this.content.style.removeProperty("display");

      this.portalContent();

      this.content.setAttribute("data-state", "open");

      // Update the list of dropdown items
      this.updateDropdownItems();

      // Reset focus index when opening
      this.currentFocusIndex = -1;

      this.positionContent({ avoidCollisions: true });

      requestAnimationFrame(() => {
        this.positionContent({ avoidCollisions: true });
      });

      // For submenus opened by keyboard, focus the first item
      if (this.isSubmenu && this.lastOpenSource === "keyboard") {
        requestAnimationFrame(() => {
          this.focusItem(0);
        });
      }
    }

    private closeDropdown(options?: { skipFocus?: boolean; skipParentHoverClose?: boolean }) {
      if (!this.isOpen) return;
      if (!this.content || !this.trigger) return;

      this.isClosing = true;
      this.isOpen = false;
      this.initialCursorPoint = null;
      this.skipParentHoverCloseOnUnmount = options?.skipParentHoverClose === true;
      this.content.setAttribute("data-state", "closed");

      // Set focus back on trigger only if opened or closed by keyboard
      // Skip focus if a close-all with focusRoot is closing this submenu (root will handle focus)
      if (
        !options?.skipFocus &&
        (!this.openOnHover ||
          this.lastOpenSource === "keyboard" ||
          this.lastCloseSource === "keyboard")
      ) {
        requestAnimationFrame(() => {
          if (!this.trigger) return;
          this.trigger.focus();
        });
      }

      // Give the content time to animate before hiding
      if (this.closeTimeoutRef !== null) {
        window.clearTimeout(this.closeTimeoutRef);
      }

      this.closeTimeoutRef = window.setTimeout(() => {
        this.closeTimeoutRef = null;
        if (!this.content) return;
        this.unportalContent();
        this.content.style.display = "none";
        this.isClosing = false;
      }, this.animationDuration);

      this.trigger.setAttribute("aria-expanded", "false");

      // Reset focus index when closing
      this.currentFocusIndex = -1;
    }

    private closeDropdownDelayed() {
      if (!this.content || !this.trigger) return;

      // Clear any existing close timer
      this.clearCloseTimer();

      // Set a new timer to close the dropdown after the delay
      this.closeTimerRef = window.setTimeout(() => {
        if (this.isOpen) {
          this.closeDropdown();
        }
        this.closeTimerRef = null;
      }, this.closeDelay);
    }

    private clearCloseTimer() {
      if (this.closeTimerRef !== null) {
        window.clearTimeout(this.closeTimerRef);
        this.closeTimerRef = null;
      }
    }

    private clearLongPressTimer() {
      if (this.longPressTimerRef !== null) {
        window.clearTimeout(this.longPressTimerRef);
        this.longPressTimerRef = null;
      }
    }

    private isPointerWithinDropdownGroup(): boolean {
      if (this.trigger?.matches(":hover") || this.content?.matches(":hover")) {
        return true;
      }

      const hoveredElements = Array.from(document.querySelectorAll(":hover"));
      return hoveredElements.some(
        (element) =>
          this.dropdown.contains(element) ||
          this.content?.contains(element) ||
          this.isTargetInGroup(element),
      );
    }

    destroy() {
      if (this.abortController.signal.aborted) return;

      this.abortController.abort();
      this.clearCloseTimer();
      this.clearLongPressTimer();

      if (this.closeTimeoutRef !== null) {
        window.clearTimeout(this.closeTimeoutRef);
        this.closeTimeoutRef = null;
      }

      this.unportalContent();
      this.isOpen = false;
      this.isClosing = false;
      this.anchorRect = null;
      this.initialCursorPoint = null;
      this.touchStartPoint = null;
      this.currentFocusIndex = -1;

      if (this.trigger) {
        this.trigger.setAttribute("aria-expanded", "false");
      }

      if (this.content) {
        this.content.setAttribute("data-state", "closed");
        this.content.style.display = "none";
      }
    }

    private portalContent() {
      if (!this.content || !this.trigger) return;
      const portalTarget = this.resolvePortalTarget();
      if (this.contentPlaceholder || this.content.parentElement === portalTarget) return;

      // Save the original position with a placeholder
      this.contentPlaceholder = document.createComment("dropdown-content-placeholder");
      this.content.parentNode?.insertBefore(this.contentPlaceholder, this.content);

      // Move content to body
      portalTarget.appendChild(this.content);
      this.portalTarget = portalTarget;

      // Apply fixed positioning (overrides the CSS absolute class)
      this.content.style.position = portalTarget === document.body ? "fixed" : "absolute";

      // Position relative to trigger
      this.positionContent({ avoidCollisions: true });

      // Set up auto-update for scroll/resize
      const handleScroll = () => this.positionContent({ avoidCollisions: false });
      const handleResize = () => this.positionContent({ avoidCollisions: true });
      window.addEventListener("scroll", handleScroll, true);
      window.addEventListener("resize", handleResize);

      const resizeObserver = new ResizeObserver(() =>
        this.positionContent({ avoidCollisions: true }),
      );
      resizeObserver.observe(this.content);
      resizeObserver.observe(this.trigger);

      // Find and link to parent handler for child-tracking
      const parentContent = this.trigger.closest(
        '[data-slot="dropdown-content"], [data-slot="context-menu-content"]',
      );
      if (parentContent) {
        this.parentHandler = (parentContent as any).__dropdownHandler || null;
        if (this.parentHandler) {
          this.parentHandler.openChildCount++;
        }
      }

      // Handle hover interactions for portaled content
      const onPointerEnter = (e: PointerEvent) => {
        if (e.pointerType !== "mouse") return;
        this.clearCloseTimer();
        // Cancel close timers for all handlers in the group (parents included)
        this.rootDropdown.dispatchEvent(new CustomEvent("starwind-dropdown:cancel-close"));
      };

      const onPointerLeave = (e: PointerEvent) => {
        if (e.pointerType !== "mouse") return;
        // Don't close if a child submenu is still open
        if (this.openChildCount > 0) return;
        this.lastCloseSource = "mouse";
        this.closeDropdownDelayed();
      };

      if (this.openOnHover) {
        this.content.addEventListener("pointerenter", onPointerEnter);
        this.content.addEventListener("pointerleave", onPointerLeave);
      }

      this.cleanupAutoUpdate = () => {
        window.removeEventListener("scroll", handleScroll, true);
        window.removeEventListener("resize", handleResize);
        resizeObserver.disconnect();
        if (this.openOnHover) {
          this.content?.removeEventListener("pointerenter", onPointerEnter);
          this.content?.removeEventListener("pointerleave", onPointerLeave);
        }
      };
    }

    private unportalContent() {
      if (!this.content) return;

      // Decrement parent's open child count
      if (this.parentHandler) {
        const parentHandler = this.parentHandler;
        parentHandler.openChildCount = Math.max(0, parentHandler.openChildCount - 1);
        this.parentHandler = null;

        if (
          !this.skipParentHoverCloseOnUnmount &&
          parentHandler.openOnHover &&
          parentHandler.openChildCount === 0 &&
          !parentHandler.isPointerWithinDropdownGroup()
        ) {
          parentHandler.lastCloseSource = "mouse";
          parentHandler.closeDropdownDelayed();
        }
      }
      this.skipParentHoverCloseOnUnmount = false;

      // Clean up auto-update and hover listeners
      this.cleanupAutoUpdate?.();
      this.cleanupAutoUpdate = null;

      // Move content back to its original position
      if (this.contentPlaceholder) {
        if (this.contentPlaceholder.parentNode) {
          this.contentPlaceholder.parentNode.insertBefore(this.content, this.contentPlaceholder);
        } else if (this.content.parentNode) {
          this.content.remove();
        }
        this.contentPlaceholder.remove();
        this.contentPlaceholder = null;
      } else if (
        this.content.parentNode &&
        this.portalTarget &&
        this.portalTarget !== document.body
      ) {
        this.content.remove();
      }

      this.portalTarget = null;

      // Remove fixed positioning styles
      this.content.style.removeProperty("position");
      this.content.style.removeProperty("top");
      this.content.style.removeProperty("left");
      this.content.style.removeProperty("transform-origin");
    }

    private syncDropdownWidth() {
      if (!this.content || !this.trigger || this.isSubmenu || this.isContextMenu) return;

      this.content.style.width = "var(--starwind-dropdown-trigger-width)";
      this.content.style.setProperty(
        "--starwind-dropdown-trigger-width",
        `${this.trigger.offsetWidth}px`,
      );
    }

    private positionContent(options?: { avoidCollisions?: boolean }) {
      if (!this.content || !this.trigger || !this.isOpen) return;

      this.syncDropdownWidth();

      const triggerRect =
        this.isContextMenu && !this.isSubmenu && this.anchorRect
          ? this.anchorRect
          : this.trigger.getBoundingClientRect();
      const contentWidth = this.content.offsetWidth;
      const contentHeight = this.content.offsetHeight;
      const viewportWidth = window.innerWidth;
      const viewportHeight = window.innerHeight;
      const viewportPadding = 8;

      const resolvedPlacement = resolvePlacement({
        side: this.side,
        align: this.align,
        sideOffset: this.sideOffset,
        triggerRect,
        contentWidth,
        contentHeight,
        viewportWidth,
        viewportHeight,
        viewportPadding,
        avoidCollisions: options?.avoidCollisions ?? true,
      });

      const portalTargetRect =
        this.portalTarget && this.portalTarget !== document.body
          ? this.portalTarget.getBoundingClientRect()
          : null;
      const left = portalTargetRect
        ? resolvedPlacement.left - portalTargetRect.left
        : resolvedPlacement.left;
      const top = portalTargetRect
        ? resolvedPlacement.top - portalTargetRect.top
        : resolvedPlacement.top;

      this.content.style.left = `${Math.round(left)}px`;
      this.content.style.top = `${Math.round(top)}px`;
      this.content.style.transformOrigin = getTransformOrigin(
        resolvedPlacement.side,
        resolvedPlacement.align,
      );
      this.content.setAttribute("data-side", resolvedPlacement.side);
      this.content.setAttribute("data-align", resolvedPlacement.align);
    }
  }

  const dropdownInstances = new Map<HTMLElement, DropdownHandler>();
  let dropdownCounter = 0;

  const cleanupStaleDropdowns = () => {
    for (const [dropdownEl, dropdownHandler] of dropdownInstances.entries()) {
      if (!document.contains(dropdownEl)) {
        dropdownHandler.destroy();
        dropdownInstances.delete(dropdownEl);
      }
    }
  };

  const destroyAllDropdowns = () => {
    for (const dropdownHandler of dropdownInstances.values()) {
      dropdownHandler.destroy();
    }

    dropdownInstances.clear();
  };

  const initDropdowns = () => {
    cleanupStaleDropdowns();

    document.querySelectorAll(".starwind-dropdown, .starwind-dropdown-sub").forEach((dropdown) => {
      if (dropdown instanceof HTMLElement && !dropdownInstances.has(dropdown)) {
        dropdownInstances.set(dropdown, new DropdownHandler(dropdown, dropdownCounter++));
      }
    });
  };

  initDropdowns();
  document.addEventListener("astro:before-swap", destroyAllDropdowns);
  document.addEventListener("astro:after-swap", initDropdowns);
  document.addEventListener("starwind:init", initDropdowns);
</script>
