---
import siteConfig, { SOCIALS } from "@/configs/site.config";
import { addForwardSlashAndBaseUrl } from "@/utils/url";
import { Icon } from "astro-icon/components";
import GithubButton from "../widgets/GithubButton.astro";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"footer"> {}

const { class: className, ...props } = Astro.props;
---

<footer class:list={["border-t bg-muted", className]} {...props}>
	<div class="h-full w-full max-w-7xl mx-auto p-10">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
			<div class="col-span-2">
				<p class="text-xl">
					Maintained by <span class="font-excalifont"
						>{siteConfig.footer.maintainer.name}</span
					>
				</p>
				<p class="text-lg font-medium">
					(<span class="font-excalifont"
						>{siteConfig.footer.maintainer.designation}</span
					>)
				</p>
				<br />
				<div class="flex gap-4 mt-3">
					{
						SOCIALS.map((social) => (
							<a href={social.url} target="_blank">
								<Icon
									name={social.iconify}
									class="w-7 h-7 text-muted-foreground hover:text-foreground"
								/>
							</a>
						))
					}
				</div>
				<br />
				<p>{siteConfig.site.description}</p>
			</div>
			<div class="col-span-1">
				<p class="text-lg font-medium mb-2">Quick Links</p>
				<ul class="font-excalifont">
					<li>
						<GithubButton />
					</li>
					{
						siteConfig.footer.links.map((link) => (
							<li class="my-2">
								<a
									href={
										link.type === "external"
											? link.url
											: addForwardSlashAndBaseUrl(
													link.url,
												)
									}
									class="flex text-muted-foreground hover:text-foreground"
									target={
										link.type === "external"
											? "_blank"
											: "_self"
									}
								>
									{link.name}
									{link.type === "external" && (
										<Icon
											name="mdi:arrow-top-right"
											class="w-3 h-3"
										/>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<br />
		<p class="w-full text-center">
			Built with <a
				href="https://astro.build"
				target="_blank"
				class="underline"
			>
				<Icon name="astro" class="inline" />
			</a>
		</p>
		<p class="w-full text-center">
			Last updated on <span class="font-excalifont"
				>{
					new Date().toLocaleString("en-IN", {
						timeZone: siteConfig.site.timezone,
					})
				}
			</span> (IST)
		</p>
	</div>
</footer>
